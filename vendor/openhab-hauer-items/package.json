{
  "name": "openhab-hauer-items",
  "version": "0.0.1",
  "description": "Generated item constants and semantic metadata for the Hauer openHAB installation",
  "private": true,
  "license": "UNLICENSED",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/esm/index.js",
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js",
      "default": "./dist/esm/index.js"
    },
    "./items": {
      "types": "./dist/items.d.ts",
      "browser": "./dist/esm/items.js",
      "import": "./dist/esm/items.js",
      "require": "./dist/items.js",
      "default": "./dist/esm/items.js"
    },
    "./generated-items": {
      "types": "./dist/generated-items.d.ts",
      "browser": "./dist/esm/generated-items.js",
      "import": "./dist/esm/generated-items.js",
      "require": "./dist/generated-items.js",
      "default": "./dist/esm/generated-items.js"
    },
    "./item-meta": {
      "types": "./dist/item-meta.d.ts",
      "browser": "./dist/esm/item-meta.js",
      "import": "./dist/esm/item-meta.js",
      "require": "./dist/item-meta.js",
      "default": "./dist/esm/item-meta.js"
    },
    "./batteries": {
      "types": "./dist/batteries.d.ts",
      "browser": "./dist/esm/batteries.js",
      "import": "./dist/esm/batteries.js",
      "require": "./dist/batteries.js",
      "default": "./dist/esm/batteries.js"
    },
    "./lights": {
      "types": "./dist/lights.d.ts",
      "browser": "./dist/esm/lights.js",
      "import": "./dist/esm/lights.js",
      "require": "./dist/lights.js",
      "default": "./dist/esm/lights.js"
    },
    "./openings": {
      "types": "./dist/openings.d.ts",
      "browser": "./dist/esm/openings.js",
      "import": "./dist/esm/openings.js",
      "require": "./dist/openings.js",
      "default": "./dist/esm/openings.js"
    },
    "./presence": {
      "types": "./dist/presence.d.ts",
      "browser": "./dist/esm/presence.js",
      "import": "./dist/esm/presence.js",
      "require": "./dist/presence.js",
      "default": "./dist/esm/presence.js"
    },
    "./custom-tags": {
      "types": "./dist/custom-tags.d.ts",
      "browser": "./dist/esm/custom-tags.js",
      "import": "./dist/esm/custom-tags.js",
      "require": "./dist/custom-tags.js",
      "default": "./dist/esm/custom-tags.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "model"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hauerm/openhab-automation.git"
  },
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo tsconfig.esm.tsbuildinfo && tsc -p tsconfig.json && tsc -p tsconfig.esm.json && node scripts/write-esm-package-json.js",
    "generate:items": "node scripts/generate-items.js"
  },
  "keywords": [
    "openHAB",
    "JSScripting"
  ],
  "author": "Michael Hauer",
  "bugs": {
    "url": "https://github.com/hauerm/openhab-automation/issues"
  }
}
